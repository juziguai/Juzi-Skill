{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "loaded", "missing"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["passed", "failed"]
    },
    "loaded": {
      "type": "array",
      "items": {"type": "string"}
    },
    "missing": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
